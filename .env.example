APP_NAME=Core ERP API
DEBUG=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_db
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256

# Bootstrap seed (scripts/seed.py) — required to create first admin user
ADMIN_EMAIL=admin@erp.uz
ADMIN_PASSWORD=change-me-strong-password
ADMIN_FULL_NAME=Super Admin

# Set false if you run Alembic in CI/release only (e.g. multiple workers)
RUN_MIGRATIONS_ON_STARTUP=true

# WMS outbound (integration worker) — mock by default
WMS_MOCK_MODE=true
WMS_BASE_URL=
WMS_API_KEY=
WMS_HTTP_TIMEOUT_SECONDS=30

# Integration worker (scripts/run_worker.py)
INTEGRATION_JOB_MAX_ATTEMPTS=5
INTEGRATION_WORKER_BATCH_SIZE=10
INTEGRATION_JOB_STALE_PROCESSING_SECONDS=900
# 0 = run one batch and exit (cron-friendly); >0 = loop sleep seconds
INTEGRATION_WORKER_LOOP_SECONDS=0
